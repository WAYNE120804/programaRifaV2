generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RolUsuario {
  ADMIN
  CAJERO
  VENDEDOR
}

enum EstadoProducto {
  ACTIVO
  INACTIVO
  AGOTADO
}

enum GeneroProducto {
  MASCULINO
  FEMENINO
  UNISEX
}

enum TipoCodigoProducto {
  INTERNO
  BARRAS
}

enum TipoMovimientoInventario {
  ENTRADA_INICIAL
  COMPRA
  AJUSTE_ENTRADA
  AJUSTE_SALIDA
  VENTA
  DEVOLUCION_CLIENTE
  DEVOLUCION_PROVEEDOR
  SEPARADO
  ENTREGA_SEPARADO
  CREDITO
  SALIDA_PRESTAMO
  RETORNO_PRESTAMO
  TRUEQUE_SALIDA
  TRUEQUE_ENTRADA
  MERMA
}

enum EstadoVenta {
  ABIERTA
  PAGADA
  ANULADA
}

enum MetodoPago {
  EFECTIVO
  NEQUI
  DAVIPLATA
  TRANSFERENCIA
  TARJETA
  MIXTO
  OTRO
}

enum EstadoPagoVenta {
  CONFIRMADO
  ANULADO
}

enum CategoriaGasto {
  NOMINA
  ARRIENDO
  SERVICIOS
  PROVEEDOR
  TRANSPORTE
  MERCADEO
  MANTENIMIENTO
  IMPUESTOS
  PAPELERIA
  OTROS
}

enum TipoMovimientoCaja {
  INGRESO
  EGRESO
  TRASLADO_SALIDA
  TRASLADO_ENTRADA
  APERTURA
  CIERRE
}

enum TipoCaja {
  PRINCIPAL
  DIARIA
  MAYOR
  BANCARIA
  OTRO
}

enum EstadoCaja {
  ABIERTA
  CERRADA
  BLOQUEADA
}

enum OrigenApartadoFondo {
  CAJA_DIARIA
  CAJA_GENERAL
}

enum OrigenGasto {
  CAJA_DIARIA
  CAJA_GENERAL
  FONDO_META
}

enum EstadoSeparado {
  ACTIVO
  PAGADO
  ENTREGADO
  VENCIDO
  CANCELADO
}

enum EstadoCredito {
  ACTIVO
  PAGADO
  VENCIDO
  CANCELADO
}

enum EstadoSalidaProducto {
  PRESTADO
  DEVUELTO
  VENDIDO_EXTERNAMENTE
  TRUEQUEADO
  CANCELADO
}

enum TipoSalidaProducto {
  PRESTAMO
  CONSIGNACION
  TRUEQUE
  MUESTRA
  OTRO
}

model Usuario {
  id        String     @id @default(cuid())
  nombre    String
  email     String     @unique
  password  String
  rol       RolUsuario
  activo    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  movimientosInventario MovimientoInventario[]
  ventas                 Venta[]
  pagosVenta             PagoVenta[]
  gastos                 Gasto[]
  movimientosCaja        MovimientoCaja[]
  cierresCaja            CierreCaja[]          @relation("CierreCajaUsuario")
  retirosCajaMayor       RetiroCajaMayor[]
  apartadosFondo         FondoApartado[]
  clientesCreados        Cliente[]             @relation("ClienteCreadoPor")
  separadosCreados       Separado[]            @relation("SeparadoCreadoPor")
  abonosSeparado         SeparadoAbono[]
  creditosCreados        Credito[]             @relation("CreditoCreadoPor")
  pagosCredito           CreditoPago[]
  salidasProducto        SalidaProducto[]
}

model CategoriaProducto {
  id          String    @id @default(cuid())
  nombre      String    @unique
  codigo      String?   @unique @db.VarChar(2)
  descripcion String?
  activa      Boolean   @default(true)
  orden       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  productos Producto[]

  @@index([activa, nombre])
}

model Producto {
  id               String         @id @default(cuid())
  categoriaId      String
  nombre           String
  descripcion      String?
  marca            String?
  genero           GeneroProducto @default(UNISEX)
  estado           EstadoProducto @default(ACTIVO)
  imagenUrl        String?
  notas            String?        @db.Text
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  categoria            CategoriaProducto     @relation(fields: [categoriaId], references: [id])
  variantes            ProductoVariante[]

  @@index([categoriaId, nombre])
  @@index([estado, nombre])
}

model ProductoVariante {
  id                  String         @id @default(cuid())
  productoId          String
  talla               String
  color               String
  sku                 String         @unique
  costoPromedio       Decimal        @default(0) @db.Decimal(12,2)
  precioVenta         Decimal        @default(0) @db.Decimal(12,2)
  stockActual         Int            @default(0)
  stockMinimo         Int            @default(0)
  estado              EstadoProducto @default(ACTIVO)
  permiteDecimal      Boolean        @default(false)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  producto             Producto              @relation(fields: [productoId], references: [id], onDelete: Cascade)
  codigos              CodigoProducto[]
  movimientosInventario MovimientoInventario[]
  ventaItems           VentaItem[]
  separadoItems        SeparadoItem[]
  creditoItems         CreditoItem[]
  salidaItems          SalidaProductoItem[]

  @@unique([productoId, color, talla])
  @@index([productoId, estado])
  @@index([estado, stockActual])
}

model CodigoProducto {
  id          String            @id @default(cuid())
  varianteId   String
  codigo      String            @unique
  tipo        TipoCodigoProducto @default(BARRAS)
  principal   Boolean           @default(false)
  createdAt   DateTime          @default(now())

  variante ProductoVariante @relation(fields: [varianteId], references: [id], onDelete: Cascade)

  @@index([varianteId, principal])
}

model Cliente {
  id               String    @id @default(cuid())
  nombreCompleto    String
  cedula           String    @unique
  telefonoCelular   String
  email            String?
  fechaNacimiento  DateTime?
  direccion        String?
  observaciones    String?   @db.Text
  createdById      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  createdBy     Usuario?        @relation("ClienteCreadoPor", fields: [createdById], references: [id])
  ventas        Venta[]
  separados     Separado[]
  creditos      Credito[]
  salidasProducto SalidaProducto[]

  @@index([nombreCompleto])
  @@index([telefonoCelular])
}

model MovimientoInventario {
  id              String                  @id @default(cuid())
  varianteId      String
  usuarioId       String?
  tipo            TipoMovimientoInventario
  cantidad        Int
  stockAnterior   Int
  stockPosterior  Int
  costoUnitario   Decimal?                @db.Decimal(12,2)
  precioUnitario  Decimal?                @db.Decimal(12,2)
  detalle         String?                 @db.Text
  referenciaTipo  String?
  referenciaId    String?
  createdAt       DateTime                @default(now())

  variante ProductoVariante @relation(fields: [varianteId], references: [id], onDelete: Cascade)
  usuario  Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([varianteId, createdAt])
  @@index([tipo, createdAt])
  @@index([referenciaTipo, referenciaId])
}

model Caja {
  id           String      @id @default(cuid())
  nombre       String      @unique
  tipo         TipoCaja    @default(DIARIA)
  estado       EstadoCaja  @default(ABIERTA)
  saldoActual  Decimal     @default(0) @db.Decimal(12,2)
  descripcion  String?
  permiteVenta Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  ventas            Venta[]
  pagosVenta        PagoVenta[]
  gastos            Gasto[]
  movimientos       MovimientoCaja[]
  cierres           CierreCaja[]
  retirosOrigen     RetiroCajaMayor[] @relation("RetiroCajaOrigen")
  retirosDestino    RetiroCajaMayor[] @relation("RetiroCajaDestino")
  apartadosFondo     FondoApartado[]
  abonosSeparado    SeparadoAbono[]
  pagosCredito      CreditoPago[]

  @@index([tipo, estado])
}

model Venta {
  id             String       @id @default(cuid())
  clienteId      String?
  usuarioId      String?
  cajaId         String?
  numero         Int          @default(autoincrement())
  estado         EstadoVenta  @default(ABIERTA)
  subtotal       Decimal      @default(0) @db.Decimal(12,2)
  descuento      Decimal      @default(0) @db.Decimal(12,2)
  total          Decimal      @default(0) @db.Decimal(12,2)
  totalPagado    Decimal      @default(0) @db.Decimal(12,2)
  utilidadTotal  Decimal      @default(0) @db.Decimal(12,2)
  observaciones  String?      @db.Text
  anuladaAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  cliente Cliente? @relation(fields: [clienteId], references: [id])
  usuario Usuario? @relation(fields: [usuarioId], references: [id])
  caja    Caja?    @relation(fields: [cajaId], references: [id])

  items        VentaItem[]
  pagos        PagoVenta[]
  movimientosCaja MovimientoCaja[]

  @@unique([numero])
  @@index([estado, createdAt])
  @@index([clienteId, createdAt])
}

model VentaItem {
  id             String   @id @default(cuid())
  ventaId        String
  varianteId     String
  cantidad       Int
  costoUnitario  Decimal  @default(0) @db.Decimal(12,2)
  precioUnitario Decimal  @default(0) @db.Decimal(12,2)
  descuento      Decimal  @default(0) @db.Decimal(12,2)
  subtotal       Decimal  @default(0) @db.Decimal(12,2)
  utilidad       Decimal  @default(0) @db.Decimal(12,2)
  createdAt      DateTime @default(now())

  venta    Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  variante ProductoVariante @relation(fields: [varianteId], references: [id])

  @@index([ventaId])
  @@index([varianteId])
}

model PagoVenta {
  id          String           @id @default(cuid())
  ventaId      String
  usuarioId    String?
  cajaId       String?
  metodo       MetodoPago
  estado       EstadoPagoVenta @default(CONFIRMADO)
  valor        Decimal         @db.Decimal(12,2)
  referencia   String?
  observacion  String?         @db.Text
  createdAt    DateTime        @default(now())

  venta   Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  usuario Usuario? @relation(fields: [usuarioId], references: [id])
  caja    Caja?    @relation(fields: [cajaId], references: [id])

  movimientosCaja MovimientoCaja[]

  @@index([ventaId, createdAt])
  @@index([cajaId, createdAt])
}

model Gasto {
  id           String         @id @default(cuid())
  usuarioId     String?
  cajaId        String?
  fondoId       String?
  origen        OrigenGasto    @default(CAJA_DIARIA)
  categoria     CategoriaGasto @default(OTROS)
  descripcion   String
  valor         Decimal        @db.Decimal(12,2)
  saldoOrigenAnterior  Decimal        @default(0) @db.Decimal(12,2)
  saldoOrigenPosterior Decimal        @default(0) @db.Decimal(12,2)
  soporte       String?
  observacion   String?        @db.Text
  anuladoAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  usuario Usuario? @relation(fields: [usuarioId], references: [id])
  caja    Caja?    @relation(fields: [cajaId], references: [id])
  fondo   FondoMeta? @relation(fields: [fondoId], references: [id])

  movimientosCaja MovimientoCaja[]

  @@index([categoria, createdAt])
  @@index([cajaId, createdAt])
  @@index([fondoId, createdAt])
  @@index([origen, createdAt])
}

model MovimientoCaja {
  id             String              @id @default(cuid())
  cajaId          String
  usuarioId       String?
  ventaId         String?
  pagoVentaId     String?
  gastoId         String?
  tipo            TipoMovimientoCaja
  valor           Decimal             @db.Decimal(12,2)
  saldoAnterior   Decimal             @default(0) @db.Decimal(12,2)
  saldoPosterior  Decimal             @default(0) @db.Decimal(12,2)
  descripcion     String?
  referenciaTipo  String?
  referenciaId    String?
  createdAt       DateTime            @default(now())

  caja      Caja      @relation(fields: [cajaId], references: [id], onDelete: Cascade)
  usuario   Usuario?  @relation(fields: [usuarioId], references: [id])
  venta     Venta?    @relation(fields: [ventaId], references: [id])
  pagoVenta PagoVenta? @relation(fields: [pagoVentaId], references: [id])
  gasto     Gasto?    @relation(fields: [gastoId], references: [id])

  @@index([cajaId, createdAt])
  @@index([tipo, createdAt])
}

model CierreCaja {
  id                String    @id @default(cuid())
  cajaId            String
  usuarioId         String?
  fechaApertura     DateTime
  fechaCierre       DateTime  @default(now())
  saldoInicial      Decimal   @default(0) @db.Decimal(12,2)
  saldoEsperado     Decimal   @default(0) @db.Decimal(12,2)
  saldoReal         Decimal   @default(0) @db.Decimal(12,2)
  diferencia        Decimal   @default(0) @db.Decimal(12,2)
  observaciones     String?   @db.Text
  createdAt         DateTime  @default(now())

  caja    Caja     @relation(fields: [cajaId], references: [id], onDelete: Cascade)
  usuario Usuario? @relation("CierreCajaUsuario", fields: [usuarioId], references: [id])

  @@index([cajaId, fechaCierre])
}

model RetiroCajaMayor {
  id             String    @id @default(cuid())
  usuarioId       String?
  cajaOrigenId    String
  cajaDestinoId   String?
  valor           Decimal   @db.Decimal(12,2)
  motivo          String
  observacion     String?   @db.Text
  createdAt       DateTime  @default(now())

  usuario    Usuario? @relation(fields: [usuarioId], references: [id])
  cajaOrigen Caja     @relation("RetiroCajaOrigen", fields: [cajaOrigenId], references: [id])
  cajaDestino Caja?   @relation("RetiroCajaDestino", fields: [cajaDestinoId], references: [id])

  @@index([cajaOrigenId, createdAt])
  @@index([cajaDestinoId, createdAt])
}

model FondoMeta {
  id          String   @id @default(cuid())
  nombre      String   @unique
  metaTotal   Decimal  @default(0) @db.Decimal(12,2)
  acumulado   Decimal  @default(0) @db.Decimal(12,2)
  notas       String?  @db.Text
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  apartados FondoApartado[]
  gastos    Gasto[]

  @@index([activo, nombre])
}

model FondoApartado {
  id                   String              @id @default(cuid())
  fondoId              String
  usuarioId            String?
  cajaId               String
  origen               OrigenApartadoFondo
  valor                Decimal             @db.Decimal(12,2)
  saldoFondoAnterior   Decimal             @default(0) @db.Decimal(12,2)
  saldoFondoPosterior  Decimal             @default(0) @db.Decimal(12,2)
  saldoCajaAnterior    Decimal             @default(0) @db.Decimal(12,2)
  saldoCajaPosterior   Decimal             @default(0) @db.Decimal(12,2)
  observacion          String?             @db.Text
  createdAt            DateTime            @default(now())

  fondo   FondoMeta @relation(fields: [fondoId], references: [id], onDelete: Cascade)
  usuario Usuario?  @relation(fields: [usuarioId], references: [id])
  caja    Caja      @relation(fields: [cajaId], references: [id])

  @@index([fondoId, createdAt])
  @@index([cajaId, createdAt])
  @@index([origen, createdAt])
}

model Separado {
  id              String         @id @default(cuid())
  clienteId        String
  usuarioId        String?
  estado           EstadoSeparado @default(ACTIVO)
  fechaLimite      DateTime?
  subtotal         Decimal        @default(0) @db.Decimal(12,2)
  total            Decimal        @default(0) @db.Decimal(12,2)
  totalAbonado     Decimal        @default(0) @db.Decimal(12,2)
  saldoPendiente   Decimal        @default(0) @db.Decimal(12,2)
  observaciones    String?        @db.Text
  entregadoAt      DateTime?
  canceladoAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  cliente Cliente  @relation(fields: [clienteId], references: [id])
  usuario Usuario? @relation("SeparadoCreadoPor", fields: [usuarioId], references: [id])

  items   SeparadoItem[]
  abonos  SeparadoAbono[]

  @@index([clienteId, estado])
  @@index([fechaLimite])
}

model SeparadoItem {
  id             String   @id @default(cuid())
  separadoId      String
  varianteId      String
  cantidad        Int
  costoUnitario   Decimal  @default(0) @db.Decimal(12,2)
  precioUnitario  Decimal  @default(0) @db.Decimal(12,2)
  subtotal        Decimal  @default(0) @db.Decimal(12,2)
  createdAt       DateTime @default(now())

  separado Separado @relation(fields: [separadoId], references: [id], onDelete: Cascade)
  variante ProductoVariante @relation(fields: [varianteId], references: [id])

  @@index([separadoId])
  @@index([varianteId])
}

model SeparadoAbono {
  id          String     @id @default(cuid())
  separadoId   String
  usuarioId    String?
  cajaId       String?
  metodo       MetodoPago
  valor        Decimal    @db.Decimal(12,2)
  referencia   String?
  observacion  String?    @db.Text
  createdAt    DateTime   @default(now())

  separado Separado @relation(fields: [separadoId], references: [id], onDelete: Cascade)
  usuario  Usuario? @relation(fields: [usuarioId], references: [id])
  caja     Caja?    @relation(fields: [cajaId], references: [id])

  @@index([separadoId, createdAt])
}

model Credito {
  id              String         @id @default(cuid())
  clienteId        String
  usuarioId        String?
  estado           EstadoCredito @default(ACTIVO)
  subtotal         Decimal       @default(0) @db.Decimal(12,2)
  total            Decimal       @default(0) @db.Decimal(12,2)
  totalPagado      Decimal       @default(0) @db.Decimal(12,2)
  saldoPendiente   Decimal       @default(0) @db.Decimal(12,2)
  fechaInicio      DateTime      @default(now())
  fechaLimite      DateTime?
  observaciones    String?       @db.Text
  entregadoAt      DateTime?
  canceladoAt      DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  cliente Cliente  @relation(fields: [clienteId], references: [id])
  usuario Usuario? @relation("CreditoCreadoPor", fields: [usuarioId], references: [id])

  items  CreditoItem[]
  pagos  CreditoPago[]

  @@index([clienteId, estado])
  @@index([fechaLimite])
}

model CreditoItem {
  id             String   @id @default(cuid())
  creditoId       String
  varianteId      String
  cantidad        Int
  costoUnitario   Decimal  @default(0) @db.Decimal(12,2)
  precioUnitario  Decimal  @default(0) @db.Decimal(12,2)
  subtotal        Decimal  @default(0) @db.Decimal(12,2)
  createdAt       DateTime @default(now())

  credito  Credito  @relation(fields: [creditoId], references: [id], onDelete: Cascade)
  variante ProductoVariante @relation(fields: [varianteId], references: [id])

  @@index([creditoId])
  @@index([varianteId])
}

model CreditoPago {
  id          String     @id @default(cuid())
  creditoId    String
  usuarioId    String?
  cajaId       String?
  metodo       MetodoPago
  valor        Decimal    @db.Decimal(12,2)
  referencia   String?
  observacion  String?    @db.Text
  createdAt    DateTime   @default(now())

  credito Credito @relation(fields: [creditoId], references: [id], onDelete: Cascade)
  usuario Usuario? @relation(fields: [usuarioId], references: [id])
  caja    Caja?    @relation(fields: [cajaId], references: [id])

  @@index([creditoId, createdAt])
}

model SalidaProducto {
  id                String               @id @default(cuid())
  clienteId          String?
  usuarioId          String?
  tipo              TipoSalidaProducto
  estado            EstadoSalidaProducto @default(PRESTADO)
  responsableNombre  String
  responsableCedula  String?
  responsableTelefono String?
  destino            String?
  fechaCompromiso    DateTime?
  observaciones      String?              @db.Text
  valorRecibido      Decimal?             @db.Decimal(12,2)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  cerradoAt          DateTime?

  cliente Cliente? @relation(fields: [clienteId], references: [id])
  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  items SalidaProductoItem[]

  @@index([estado, createdAt])
  @@index([tipo, createdAt])
  @@index([clienteId])
}

model SalidaProductoItem {
  id              String   @id @default(cuid())
  salidaId         String
  varianteId       String
  cantidad         Int
  costoUnitario    Decimal? @db.Decimal(12,2)
  precioReferencia Decimal? @db.Decimal(12,2)
  observacion      String?  @db.Text
  createdAt        DateTime @default(now())

  salida   SalidaProducto @relation(fields: [salidaId], references: [id], onDelete: Cascade)
  variante ProductoVariante @relation(fields: [varianteId], references: [id])

  @@index([salidaId])
  @@index([varianteId])
}
